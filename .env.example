# HTTP API
EVOLVE_AGENT_API_HOST=0.0.0.0
EVOLVE_AGENT_API_PORT=8110
EVOLVE_AGENT_CONFIG=config/config.yaml
EVOLVE_AGENT_BASE_URL=http://127.0.0.1:8110
EVOLVE_AGENT_START_WAIT_TIMEOUT=60
EVOLVE_AGENT_STOP_WAIT_TIMEOUT=20
EVOLVE_AGENT_API_LOG=logs/evolve-agent.log
EVOLVE_AGENT_API_PID_FILE=logs/evolve-agent.pid

# OpenAI-compatible LLM configuration
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime paths
EVOLVE_AGENT_EVOLVEPRO_ROOT=/mnt/disk3/tio_nekton4/EvolvePro
EVOLVE_AGENT_MULTIEVOLVE_ROOT=/mnt/disk3/tio_nekton4/MULTI-evolve
EVOLVE_AGENT_MULTIEVOLVE_MODEL_DIR=/mnt/disk3/tio_nekton4/MULTI-evolve/models
EVOLVE_AGENT_RESULT_DIR=/mnt/disk3/tio_nekton4/evolve-agent/results
EVOLVE_AGENT_TMP_DIR=/mnt/disk3/tio_nekton4/evolve-agent/tmp
EVOLVE_AGENT_UPLOAD_DIR=/mnt/disk3/tio_nekton4/evolve-agent/uploads
EVOLVE_AGENT_DEFAULT_STRATEGY=multievolve

# Conda envs
EVOLVE_AGENT_EVOLVEPRO_CONDA_ENV=evolvepro
EVOLVE_AGENT_MULTIEVOLVE_CONDA_ENV=plm

# Optional explicit command overrides, must be JSON arrays
EVOLVE_AGENT_EVOLVEPRO_COMMAND_JSON=[]
EVOLVE_AGENT_MULTIEVOLVE_TRAIN_COMMAND_JSON=[]
EVOLVE_AGENT_MULTIEVOLVE_PROPOSE_COMMAND_JSON=[]
EVOLVE_AGENT_MULTIEVOLVE_CHECKPOINT_PATH=
